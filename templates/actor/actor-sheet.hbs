<form class="{{cssClass}} flexcol" autocomplete="off">

    <!-- Заголовок -->
    <header class="sheet-header flexrow">
        <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="64" width="64"/>
        <div class="header-fields">
            <h1 class="charname">
                <input name="name" type="text" value="{{actor.name}}" placeholder="Имя / Прозвище"/>
            </h1>
            <div class="resource">
                <label>Происхождение / Класс</label>
                <input type="text" name="system.biography" value="{{system.biography}}" placeholder="Например: Оперативник / Следователь"/>
            </div>
        </div>
    </header>

    <!-- Навигация по вкладкам -->
    <nav class="sheet-tabs tabs" data-group="primary">
        <a class="item" data-tab="main">Главное</a>
        <a class="item" data-tab="inventory">Снаряжение</a>
        <a class="item" data-tab="notes">Заметки</a>
    </nav>

    <!-- Тело листа -->
    <section class="sheet-body">

        <!-- Вкладка Главное -->
        <div class="tab main" data-group="primary" data-tab="main">
            
            <!-- Атрибуты -->
            <div class="flexrow attributes-grid">
                <div class="attribute-box">
                    <label>Тело</label>
                    <input type="number" name="system.attributes.telo.value" value="{{system.attributes.telo.value}}" data-dtype="Number"/>
                    <a class="attribute-roll" data-attribute="telo" title="Бросить 2d6+Тело">🎲</a>
                </div>
                <div class="attribute-box">
                    <label>Разум</label>
                    <input type="number" name="system.attributes.razum.value" value="{{system.attributes.razum.value}}" data-dtype="Number"/>
                    <a class="attribute-roll" data-attribute="razum" title="Бросить 2d6+Разум">🎲</a>
                </div>
                <div class="attribute-box">
                    <label>Душа</label>
                    <input type="number" name="system.attributes.dusha.value" value="{{system.attributes.dusha.value}}" data-dtype="Number"/>
                    <a class="attribute-roll" data-attribute="dusha" title="Бросить 2d6+Душа">🎲</a>
                </div>
                <div class="attribute-box">
                    <label>Харизма</label>
                    <input type="number" name="system.attributes.harizma.value" value="{{system.attributes.harizma.value}}" data-dtype="Number"/>
                    <a class="attribute-roll" data-attribute="harizma" title="Бросить 2d6+Харизма">🎲</a>
                </div>
            </div>

            <!-- Страх и Раны -->
            <div class="flexrow status-grid">
                <div class="status-box fear-bar">
                    <h3>Страх (0-6)</h3>
                    <input type="number" name="system.fear.value" value="{{system.fear.value}}" min="0" max="6" data-dtype="Number"/>
                    <span> / {{system.fear.max}}</span>
                </div>
                
                <div class="status-box wounds-bar">
                    <h3>Раны</h3>
                    <label>Лёгкие: <input type="number" name="system.wounds.light.value" value="{{system.wounds.light.value}}" data-dtype="Number"/> / {{system.wounds.light.max}}</label>
                    <label>Тяжёлые: <input type="number" name="system.wounds.heavy.value" value="{{system.wounds.heavy.value}}" data-dtype="Number"/> / {{system.wounds.heavy.max}}</label>
                    <label>Крит: <input type="number" name="system.wounds.critical.value" value="{{system.wounds.critical.value}}" data-dtype="Number"/> / {{system.wounds.critical.max}}</label>
                </div>
            </div>

            <!-- Ходы и Способности (Список предметов типа 'move') -->
            <h2>Ходы и Способности</h2>
            <ol class="items-list">
                {{#each actor.items as |item id|}}
                    {{#if (eq item.type "move")}}
                    <li class="item flexrow" data-item-id="{{item._id}}">
                        <h4 class="item-name">{{item.name}}</h4>
                        <div class="item-controls">
                            <a class="item-control item-edit" title="Редактировать"><i class="fas fa-edit"></i></a>
                            <a class="item-control item-delete" title="Удалить"><i class="fas fa-trash"></i></a>
                        </div>
                    </li>
                    {{/if}}
                {{/each}}
            </ol>
        </div>

        <!-- Вкладка Снаряжение -->
        <div class="tab inventory" data-group="primary" data-tab="inventory">
            <h2>Снаряжение и Улики</h2>
            <ol class="items-list">
                {{#each actor.items as |item id|}}
                    {{#if (or (eq item.type "gear") (eq item.type "clue"))}}
                    <li class="item flexrow" data-item-id="{{item._id}}">
                        <h4 class="item-name">{{item.name}}</h4>
                        <div class="item-controls">
                            <a class="item-control item-edit" title="Редактировать"><i class="fas fa-edit"></i></a>
                            <a class="item-control item-delete" title="Удалить"><i class="fas fa-trash"></i></a>
                        </div>
                    </li>
                    {{/if}}
                {{/each}}
            </ol>
        </div>

        <!-- Вкладка Заметки -->
        <div class="tab notes" data-group="primary" data-tab="notes">
            <h2>Личная цель и Долги</h2>
            {{editor system.notes target="system.notes" button=true owner=owner editable=editable}}
        </div>

    </section>
</form>